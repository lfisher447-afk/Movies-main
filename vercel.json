{
  "version": 2,
  "builds":[
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites":[
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/health(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/BingeBox_Omega_FINAL.html"
    }
  ]
}
