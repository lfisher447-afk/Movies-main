{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds":[
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "memory": 1024,
        "maxDuration": 15
      }
    }
  ],
  "rewrites":[
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/health(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers":[
    {
      "source": "/index.html",
      "headers":[
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=31536000"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
